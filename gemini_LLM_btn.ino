// Array of all bitmaps for convenience. (Total bytes used to store images in PROGMEM = 26624)
const int epd_bitmap_allArray_LEN = 5;
const uint16_t* epd_bitmap_allArray[5] = {
	epd_bitmap_Layer_2,
	epd_bitmap_Layer_3,
	epd_bitmap_Layer_4,
	epd_bitmap_Layer_5,
	epd_bitmap_Layer_6
};

const uint8_t frameWidths[epd_bitmap_allArray_LEN] = { 82, 82, 84, 85, 84 };
const uint8_t frameHeights[epd_bitmap_allArray_LEN] = { 62, 63, 65, 64, 64 };
const uint8_t frameSequence[] = { 0, 4, 0 };
const uint8_t frameSequenceLen = sizeof(frameSequence) / sizeof(frameSequence[0]);
const uint16_t frameDelaysMs[] = { 500, 60, 500 };
const uint8_t frameDelaysLen = sizeof(frameDelaysMs) / sizeof(frameDelaysMs[0]);
const int frameMaxWidth = 85;
const int frameMaxHeight = 65;
unsigned long lastFrameMs = 0;
uint8_t frameSequenceIndex = 0;


// Audio Filter Variables
float dc_filter_y = 0;
float dc_filter_x = 0;

// Scrolling Chat Memory
#define MAX_HISTORY 4
String chatHistory[MAX_HISTORY];

void setupI2S() {
  i2s_config_t i2s_config = {
    .mode = (i2s_mode_t)(I2S_MODE_MASTER | I2S_MODE_RX | I2S_MODE_ADC_BUILT_IN),
    .sample_rate = I2S_SAMPLE_RATE,
    .bits_per_sample = I2S_BITS_PER_SAMPLE_16BIT,
    .channel_format = I2S_CHANNEL_FMT_ONLY_LEFT,
    .communication_format = I2S_COMM_FORMAT_I2S_LSB,
    .intr_alloc_flags = ESP_INTR_FLAG_LEVEL1,
    .dma_buf_count = 16,     
    .dma_buf_len = 1024,     
    .use_apll = false,
    .tx_desc_auto_clear = false,
    .fixed_mclk = 0
  };

  i2s_driver_install(I2S_NUM_0, &i2s_config, 0, NULL);
  i2s_set_adc_mode(ADC_UNIT_1, ADC1_CHANNEL_4); // GPIO 32
  i2s_adc_enable(I2S_NUM_0);
}

void drawFaceBitmap() {
	const uint8_t frameIndex = frameSequence[frameSequenceIndex];
	const uint8_t w = frameWidths[frameIndex];
	const uint8_t h = frameHeights[frameIndex];

	int16_t baseX = (tft.width() - frameMaxWidth) / 2;
	int16_t baseY = (tft.height() / 2 - frameMaxHeight) / 2;
	if (baseX < 0) baseX = 0;
	if (baseY < 0) baseY = 0;
	int16_t spriteX = (frameMaxWidth - w) / 2;
	int16_t spriteY = (frameMaxHeight - h) / 2;

	faceSprite.fillSprite(TFT_BLACK);
	faceSprite.pushImage(spriteX, spriteY, w, h, epd_bitmap_allArray[frameIndex]);
	faceSprite.pushSprite(baseX, baseY);
}

void animateFace() {
	const uint16_t frameDelay = (frameSequenceIndex < frameDelaysLen)
		? frameDelaysMs[frameSequenceIndex]
		: frameDelaysMs[0];
	if (millis() - lastFrameMs < frameDelay) return;
	lastFrameMs = millis();
	frameSequenceIndex = (frameSequenceIndex + 1) % frameSequenceLen;
	drawFaceBitmap();
}

void updateDisplay(String statusText = "Live Assistant:") {
  tft.fillScreen(TFT_BLACK);
	drawFaceBitmap();
  
  // Header
  int16_t textStartY = tft.height() / 2 + 4;
  tft.setCursor(0, textStartY);
  if (statusText == "Recording...") {
    tft.setTextColor(TFT_RED);
  } else if (statusText == "Thinking...") {
    tft.setTextColor(TFT_YELLOW);
  } else {
    tft.setTextColor(TFT_GREEN);
  }
  tft.setTextSize(1);
  tft.println(statusText);
  tft.drawLine(0, textStartY + 12, tft.width(), textStartY + 12, TFT_GREEN);
  
  // Chat History
  tft.setCursor(0, textStartY + 16);
  tft.setTextWrap(true);
  tft.setTextSize(1); 
  
  for (int i = 0; i < MAX_HISTORY; i++) {
    if (chatHistory[i].length() > 0) {
      if (i == MAX_HISTORY - 1) {
        tft.setTextColor(TFT_YELLOW); // Highlight newest message
      } else {
        tft.setTextColor(TFT_WHITE);
      }
      tft.print("> ");
      tft.println(chatHistory[i]);
      tft.println();
    }
  }
}

void pushToHistory(String newMessage) {
  for (int i = 0; i < MAX_HISTORY - 1; i++) {
    chatHistory[i] = chatHistory[i + 1];
  }
  chatHistory[MAX_HISTORY - 1] = newMessage;
  updateDisplay();
}

void setup() {
  Serial.begin(115200);
  pinMode(BUTTON_PIN, INPUT_PULLUP);

  tft.init();
  tft.setRotation(3);
	tft.setSwapBytes(true);
	faceSprite.createSprite(frameMaxWidth, frameMaxHeight);
	faceSprite.setSwapBytes(true);
  tft.fillScreen(TFT_BLACK);
  tft.setTextColor(TFT_WHITE, TFT_BLACK);
  tft.setTextSize(1);
  tft.setCursor(0, 0);
  tft.println("Connecting WiFi...");

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

	client.setTimeout(10);
  
  for(int i=0; i<MAX_HISTORY; i++) {
    chatHistory[i] = "";
  }
  
  updateDisplay("Ready. Hold BOOT.");
  setupI2S();
}

void loop() {
	animateFace();

  if (!client.connected()) {
    if (!client.connect(SERVER_IP, SERVER_PORT)) {
      Serial.println("Connection failed...");
      delay(2000);
      return;
    }
    client.setNoDelay(true); 
    updateDisplay();
  }

  // Check Button State
  bool buttonPressed = (digitalRead(BUTTON_PIN) == LOW);

  if (buttonPressed && !isRecording) {
    isRecording = true;
    client.print("___START___");
    updateDisplay("Recording...");
    delay(50); // Debounce
  } 
  else if (!buttonPressed && isRecording) {
    isRecording = false;
    client.print("___END___");
    updateDisplay("Thinking...");
    delay(50); // Debounce
  }

  // Stream Audio While Holding Button
  if (isRecording) {
    size_t bytes_read;
    uint16_t i2s_buffer[1024];
    int16_t pcm_buffer[512]; 

    i2s_read(I2S_NUM_0, &i2s_buffer, sizeof(i2s_buffer), &bytes_read, portMAX_DELAY);

    int total_samples = bytes_read / 2;
    int pcm_index = 0;

    for (int i = 0; i < total_samples; i += 2) {
      uint16_t raw_sample = i2s_buffer[i] & 0x0FFF; 
      
      float x = (float)raw_sample;
      dc_filter_y = x - dc_filter_x + 0.995 * dc_filter_y;
      dc_filter_x = x;

      float scaled_audio = dc_filter_y * 12.0;
      if (scaled_audio > 32767.0) scaled_audio = 32767.0;
      if (scaled_audio < -32768.0) scaled_audio = -32768.0;

      pcm_buffer[pcm_index++] = (int16_t)scaled_audio; 
    }

    client.write((const uint8_t*)pcm_buffer, pcm_index * 2);
  }

  // Check for LLM Response
  if (!isRecording && client.available()) {
    String response = client.readStringUntil('\n');
    response.trim(); 
    
    if (response.length() > 0) {
      pushToHistory(response);
    }
  }
}